# ─────────────────────────────────────────────────────────────────────────────
# SRE Triage Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: Gemini 2.0 Flash (primary — fast triage, ticketing, notifications) ─
GOOGLE_API_KEY=your-google-api-key-here

# ── LLM: Claude Sonnet (optional — deep log analysis, root-cause reasoning) ─
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Database (persisted to ./data/incidents.db) ─────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/incidents.db

# ── Observability (Jaeger — set automatically in Docker Compose) ────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# ── Discord (optional — leave empty for mock mode) ──────────────────────────
DISCORD_WEBHOOK_URL=

# ── Email / SMTP (optional — leave empty for mock mode) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=sre-agent@example.com

# ── Security ────────────────────────────────────────────────────────────────
ENABLE_PROMPT_INJECTION_DETECTION=true
RATE_LIMIT_PER_MINUTE=30
